{
  "name": "simply-the-quest",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "biome format",
    "build": "panda codegen && panda && react-router build",
    "db:run": "docker run --name pg-stq-dev -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "dev": "panda && react-router dev",
    "graph:init": "tsx ./app/graph/scripts/init.ts",
    "lint": "biome check",
    "panda:gen": "panda codegen && panda",
    "panda:watch": "panda --watch",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "prepare": "lefthook install; panda codegen; panda; drizzle-kit generate; react-router typegen"
  },
  "dependencies": {
    "@ark-ui/react": "^5.18.4",
    "@hookform/resolvers": "^5.2.1",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@react-router/node": "^7.7.1",
    "@react-router/serve": "^7.7.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.4",
    "isbot": "^5.1.27",
    "lucide-react": "^0.539.0",
    "neo4j-driver": "^5.28.1",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.62.0",
    "react-router": "^7.7.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.3",
    "@catppuccin/tailwindcss": "^1.0.0",
    "@pandacss/dev": "^1.0.1",
    "@park-ui/panda-preset": "^0.43.1",
    "@react-router/dev": "^7.7.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "dotenv": "^17.2.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-zod": "^0.8.2",
    "lefthook": "^1.12.2",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
